# race-analysis — environment variable template
# -----------------------------------------------
# Copy this file to .env and fill in real values.
# NEVER commit .env — it is already in .gitignore.
#
# Run `python scripts/check_env.py` to validate your setup before
# running any race-day scripts.
#
# Placeholder format: <description>  — replace the whole <…> token.
# Do NOT commit a file that still contains placeholder values.


# ─────────────────────────────────────────────────────────────────────────────
# SPORTING LIFE  (free account at https://www.sportinglife.com/racing)
# Required for authenticated form / live-odds scraping.
# Without these, the scraper receives a 373-byte JavaScript SPA shell and
# silently returns no data — the Derby Day live-odds failure (2026-06-06).
# ─────────────────────────────────────────────────────────────────────────────

# [REQUIRED] Registered email address for your Sporting Life account.
SPORTINGLIFE_USER=<your-sportinglife-email>

# [REQUIRED] Password for the Sporting Life account above.
SPORTINGLIFE_PASS=<your-sportinglife-password>


# ─────────────────────────────────────────────────────────────────────────────
# AT THE RACES  (https://www.attheraces.com)
# Used by Playwright scrapers for horse form history.
# Authentication is cookie-based; export via Cookie-Editor browser extension
# after logging in.  Defaults to .cookies/attheraces.txt if not set.
# ─────────────────────────────────────────────────────────────────────────────

# [OPTIONAL] Absolute or repo-relative path to the ATR session cookie file
# (JSON format exported by Cookie-Editor).  Defaults to:
#   .cookies/attheraces.txt
# ATR_COOKIE_FILE=<path-to-atr-cookies.txt>


# ─────────────────────────────────────────────────────────────────────────────
# RACING API  (https://api.theracingapi.com — commercial subscription)
# Not yet integrated; reserved for v0.5+ live-price ingestion.
# Leave blank / commented out until the integration is built.
# ─────────────────────────────────────────────────────────────────────────────

# [OPTIONAL — future] API key for The Racing API live-price feed.
# RACING_API_KEY=<get-from-theracingapi.com>
