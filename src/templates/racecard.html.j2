<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>{{ meeting.title }} {{ day.label }} — Betting Slip — {{ date_display }}</title>
<style>{{ css|safe }}</style>
</head>
<body>

{% if scenario_banner %}
<div class="scenario-banner {{ scenario_banner.get('class', '') }}">{{ scenario_banner.text }}</div>
{% endif %}

<header class="slip-header">
  <div class="header-left">
    <h1>{{ meeting.title }} — {{ day.label }}</h1>
    <p class="subtitle">{{ date_display }} · {{ race_count }} races · Going: {{ going_label or "TBC" }}</p>
    {% if header_nr_horses %}
    <p class="withdrawn-line">NR:
      {% for nr in header_nr_horses -%}
        <span class="nr-label">{{ nr.horse }}{% if nr.race_time %} ({{ nr.race_time }}){% endif %}</span>
        {%- if nr.rationale %} <span class="nr-reason">{{ nr.rationale }}</span>{% endif %}
        {%- if not loop.last %} · {% endif %}
      {%- endfor %}
    </p>
    {% elif non_runners %}
    <p class="withdrawn-line">Withdrawn:
      {% for nr in non_runners %}<span class="withdrawn-horse"><s>{{ nr }}</s> 🚫 NON-RUNNER</span>{% if not loop.last %}, {% endif %}{% endfor %}
    </p>
    {% endif %}
  </div>
  <div class="header-right">
    <div class="totals">
      {% if trifecta_outlay %}
      <div class="total-line"><span>WIN/EW outlay:</span> <strong>£{{ "%.2f"|format(total_stakes_gbp) }}</strong> <span class="subtotal-note">(+ £{{ "%.2f"|format(trifecta_outlay) }} trifecta = £{{ "%.2f"|format(total_outlay_gbp) }})</span></div>
      {% else %}
      <div class="total-line"><span>Total outlay:</span> <strong>£{{ "%.2f"|format(total_stakes_gbp) }}</strong></div>
      {% endif %}
      <div class="total-line"><span>Active bets:</span> <strong>{{ active_bet_count }}</strong>{% if trifecta_outlay %} <span class="subtotal-note">+ trifecta</span>{% endif %}</div>
      <div class="total-line potential"><span>Max potential:</span> <strong>£{{ "%.2f"|format(total_potential_gbp) }}</strong>{% if trifecta_outlay %} <span class="subtotal-note">(WIN/EW only)</span>{% endif %}</div>
      {% if trifecta_outlay and trifecta_horses %}
      <div class="trifecta-box">Trifecta box: {{ trifecta_horses | join(' / ') }}</div>
      {% endif %}
      {% if validation_tag %}
      <div class="validation-tag">{{ validation_tag }}</div>
      {% endif %}
    </div>
  </div>
</header>

<table class="slip">
  <thead>
    <tr>
      <th class="col-time">Time</th>
      <th class="col-race">Race</th>
      <th class="col-bet">Bet</th>
      <th class="col-horse">Horse</th>
      <th class="col-num">Odds</th>
      <th class="col-num">Stake</th>
      <th class="col-num">Potential</th>
      <th class="col-note">Note</th>
    </tr>
  </thead>
  <tbody>
    {% for row in slip_rows %}
    <tr class="row-{{ row.kind }}">
      <td class="col-time">{{ row.time }}</td>
      <td class="col-race">{{ row.race_short }}</td>
      <td class="col-bet"><span class="bet-tag bet-{{ row.bet_type|lower }}">{{ row.bet_type }}</span></td>
      <td class="col-horse">
        {% if row.withdrawn %}
          <strong><s>{{ row.horse }}</s></strong> <span class="nr-label">🚫 NON-RUNNER</span>
        {% else %}
          <strong>{{ row.horse }}</strong>{% if row.price_inline %} <span class="inline-price{% if row.price_stale %} price-stale{% endif %}">{{ row.price_inline }}</span>{% endif %}
        {% endif %}
        {% if row.kind == 'speculative' %}<br><span class="spec-tag">⚠️ SPECULATIVE — NOT A MODEL PICK</span>{% endif %}
        {% if row.kind == 'cancelled' %}<br><span class="cancel-tag">❌ CANCELLED — going downgrade</span>{% endif %}
        {% if row.trainer %}<br><span class="trainer">{{ row.trainer }}</span>{% endif %}
      </td>
      <td class="col-num">{{ "%.1f"|format(row.odds) if row.odds else "—" }}</td>
      <td class="col-num">{{ row.stake_display }}</td>
      <td class="col-num">{{ row.potential_display }}</td>
      <td class="col-note">
        {% if row.kind == 'speculative' %}
          <span class="spec-note">⚠️ SPECULATIVE</span>
          {% if row.edge_pct is not none %}<br>edge <span class="edge-negative">{{ "%+.1f"|format(row.edge_pct) }}%</span>{% endif %}
          {% if row.cancel_note %}<br><span class="cancel-note">{{ row.cancel_note }}</span>{% endif %}
        {% else %}
          {{ row.note }}
        {% endif %}
      </td>
    </tr>
    {% if row.rationale %}
    <tr class="row-rationale row-rationale-{{ row.kind }}">
      <td colspan="8"><div class="bet-rationale">▸ {{ row.rationale }}</div></td>
    </tr>
    {% endif %}
    {% endfor %}

    {% if multi_rows %}
    <tr class="row-divider"><td colspan="8">— Multiples from portfolio source —</td></tr>
    {% for row in multi_rows %}
    <tr class="row-multi">
      <td class="col-time">{{ row.time }}</td>
      <td class="col-race">{{ row.race_short }}</td>
      <td class="col-bet"><span class="bet-tag bet-{{ row.bet_type|lower }}">{{ row.bet_type }}</span></td>
      <td class="col-horse">
        {% for leg in row.legs %}
        <div class="acca-leg"><strong>{{ leg.horse }}</strong>{% if leg.price_inline %} <span class="inline-price{% if leg.price_stale %} price-stale{% endif %}">{{ leg.price_inline }}</span>{% endif %} <span class="trainer">{{ leg.time }} @ {{ "%.1f"|format(leg.odds) if leg.odds else "—" }}</span></div>
        {% endfor %}
      </td>
      <td class="col-num">{{ "%.1f"|format(row.odds) if row.odds else "—" }}</td>
      <td class="col-num">{{ row.stake_display }}</td>
      <td class="col-num">{{ row.potential_display }}</td>
      <td class="col-note">{{ row.note }}</td>
    </tr>
    {% if row.rationale %}
    <tr class="row-rationale row-rationale-multi">
      <td colspan="8"><div class="bet-rationale">▸ {{ row.rationale }}</div></td>
    </tr>
    {% endif %}
    {% endfor %}
    {% endif %}

    {% if pass_rows %}
    <tr class="row-divider"><td colspan="8">— No-bet races (model passes at current prices) —</td></tr>
    {% for row in pass_rows %}
    <tr class="row-pass">
      <td class="col-time">{{ row.time }}</td>
      <td class="col-race">{{ row.race_short }}</td>
      <td class="col-bet"><span class="bet-tag bet-pass">PASS</span></td>
      <td class="col-horse">
        {% if row.withdrawn %}<s>{{ row.horse }}</s> <span class="nr-label">🚫 NON-RUNNER</span>{% else %}{{ row.horse }} <span class="trainer">(model fancied, no value)</span>{% endif %}
      </td>
      <td class="col-num">{{ "%.1f"|format(row.odds) if row.odds else "—" }}</td>
      <td class="col-num">—</td>
      <td class="col-num">—</td>
      <td class="col-note">{{ row.note }}</td>
    </tr>
    {% endfor %}
    {% endif %}
  </tbody>
</table>

<footer class="slip-footer">
  <div class="footer-left">
    <p><strong>Legend:</strong>
       <span class="bet-tag bet-win">WIN</span> back to win &nbsp;·&nbsp;
       <span class="bet-tag bet-ew">EW</span> each-way &nbsp;·&nbsp;
       ⚡ outsider value play &nbsp;·&nbsp;
       <span class="bet-tag bet-dbl">DBL</span>/<span class="bet-tag bet-tbl">TBL</span> multiples &nbsp;·&nbsp;
       <span class="bet-tag bet-pass">PASS</span> no edge
    </p>
    <p class="disclaimer">Generated {{ generated_at }} · Model {{ model_version }}{% if market_snapshot_iso %} · Odds snapshot: {{ market_snapshot_iso }}{% endif %} · For personal use. Please gamble responsibly.</p>
  </div>
</footer>

</body>
</html>
